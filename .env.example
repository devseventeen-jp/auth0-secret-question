# Auth0 Settings
# Domain from Auth0 Application settings (e.g., dev-xyz.auth0.com)
AUTH0_DOMAIN=xxx.auth0.com
# Client ID from Auth0 Application settings
AUTH0_CLIENT_ID=your_client_id_here
# Client Secret (Machine to Machine or Regular Web App)
AUTH0_CLIENT_SECRET=your_client_secret_here
# API Audience identifier
AUTH0_AUDIENCE=https://your-api.example.com

# Django Settings
# Secret key for Django crypto signing
DJANGO_SECRET_KEY=keep_this_secret_in_prod
# Database connection string
DATABASE_URL=postgresql://django_user:django_password@db:5433/auth0_mfa_db
# Debug mode (True/False)
DEBUG=True
LOG_LEVEL=INFO
AUTH_LOG_LEVEL=DEBUG

# CORS Settings
# Allow all origins (True/False) - set to False in production
CORS_ALLOW_ALL_ORIGINS=True
# Allowed origins (comma-separated) - used when CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080,http://frontend:3000

# Email Settings (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=no-reply@example.com

# Nuxt Settings
# Auth0 config matching backend
NUXT_PUBLIC_AUTH0_DOMAIN=xxx.auth0.com
NUXT_PUBLIC_AUTH0_CLIENT_ID=your_client_id_here
NUXT_PUBLIC_AUTH0_AUDIENCE=https://your-api.example.com
NUXT_PUBLIC_AUTH0_SCOPE=openid profile email
# Auth0 callback route in Nuxt (must match Auth0 Allowed Callback URLs)
NUXT_PUBLIC_AUTH0_REDIRECT_PATH=/callback
# Base URL of the Django API
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080
# Enable cookie-based guard middleware on meeting-side frontend (true/false)
NUXT_PUBLIC_AUTH_SESSION_GUARD_ENABLED=false
# Optional explicit validation endpoint (defaults to ${NUXT_PUBLIC_API_BASE_URL}/jwt/session/validate)
NUXT_PUBLIC_AUTH_SESSION_VALIDATE_URL=
# Auth login entry URL to redirect when session is missing
NUXT_PUBLIC_AUTH_LOGIN_URL=http://localhost:3000/
# Query parameter name carrying return URL
NUXT_PUBLIC_AUTH_LOGIN_REDIRECT_PARAM=return_to
# Paths excluded from guard middleware (comma separated)
NUXT_PUBLIC_AUTH_PUBLIC_PATHS=/,/callback,/auth/callback

# Secrect Question Settings
SECRET_QUESTION_TEXT=your_secret_question_text
REAL_NAME_REQUIRED=False
NUXT_PUBLIC_APPROVAL_REDIRECT_URL=dashboard/    # https://google.com

# Callback session and cookie settings
RETURN_TO_ALLOWLIST=http://localhost:8080
INTERNAL_JWT_COOKIE_NAME=internal_jwt
INTERNAL_JWT_COOKIE_MAX_AGE=86400
INTERNAL_JWT_COOKIE_PATH=/
INTERNAL_JWT_COOKIE_DOMAIN=
INTERNAL_JWT_COOKIE_SAMESITE=Lax
INTERNAL_JWT_COOKIE_SECURE=False

# Nuxt/Nitro auth trace logs (set false to disable)
NITRO_AUTH_TRACE=true
